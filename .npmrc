# Do not run dependency lifecycle (install/postinstall) scripts.
#
# Primarily this stops electron's postinstall (apps/desktop) from downloading
# its ~150MB prebuilt binary on every `npm ci` — CI, Vercel, and fresh clones.
# The desktop shell is only type-checked and unit-tested (electron mocked via
# vitest); it is never launched here, so the runtime binary is never needed.
# The repo's other native deps (esbuild, sharp, fsevents) ship prebuilt
# platform packages and do not require their postinstall scripts.
#
# Note: this skips dependency scripts only. Explicit `npm run build` / `npm test`
# still run (npm never suppresses the directly-invoked script), so Vercel's
# build command and the test suite are unaffected.
ignore-scripts=true
