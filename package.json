{
  "name": "openbench",
  "version": "0.1.0",
  "private": true,
  "description": "The open workbench for electronics — schematic → simulation → firmware, in the browser, orchestrating open engines behind one interchange format.",
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npm run dev -w apps/web",
    "validate:ir": "vitest run packages/ir-schema"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
